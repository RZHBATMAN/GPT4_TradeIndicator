# Copy to .config and fill in values. .config is git-ignored.
# For Railway/deployed, use environment variables instead.

[API_KEYS]
OPENAI_API_KEY=your_openai_api_key
POLYGON_API_KEY=your_polygon_key

[WEBHOOKS]
TRADE_AGGRESSIVE_URL=https://...
TRADE_NORMAL_URL=https://...
TRADE_CONSERVATIVE_URL=https://...
NO_TRADE_URL=https://...

# ── Phase 2: Multi-bot parallel paper trial ──
# Bot B — Asymmetric IC (short put Δ20, short call Δ10). Same 4-tier signal as Bot A.
[WEBHOOKS_DESK_B]
DESK_B_TRADE_AGGRESSIVE_URL=https://...
DESK_B_TRADE_NORMAL_URL=https://...
DESK_B_TRADE_CONSERVATIVE_URL=https://...
DESK_B_NO_TRADE_URL=https://...

# Bot C — Put-spread only (no call leg). Same 4-tier signal as Bot A.
[WEBHOOKS_DESK_C]
DESK_C_TRADE_AGGRESSIVE_URL=https://...
DESK_C_TRADE_NORMAL_URL=https://...
DESK_C_TRADE_CONSERVATIVE_URL=https://...
DESK_C_NO_TRADE_URL=https://...

# Bot D — VVIX-conditional sizing. Static thresholds for now (placeholder for
# 252-day percentile). Maps signal tier → 4 VVIX buckets + NO_TRADE.
# OA recipe: same IC structure, contract count by bucket: LOW 0.5×, NORMAL 1×,
# HIGH 1.5×, EXTREME 2×.
[WEBHOOKS_DESK_D]
DESK_D_TRADE_VVIX_LOW_URL=https://...
DESK_D_TRADE_VVIX_NORMAL_URL=https://...
DESK_D_TRADE_VVIX_HIGH_URL=https://...
DESK_D_TRADE_VVIX_EXTREME_URL=https://...
DESK_D_NO_TRADE_URL=https://...

# Bot E — DOW-conditional sizing. Maps each tier × DOW variant.
# Mon/Fri entry → BOOST (1.5×), Tue/Wed → NORMAL (1×), Thursday → SKIP.
[WEBHOOKS_DESK_E]
DESK_E_TRADE_AGGRESSIVE_BOOST_URL=https://...
DESK_E_TRADE_AGGRESSIVE_NORMAL_URL=https://...
DESK_E_TRADE_NORMAL_BOOST_URL=https://...
DESK_E_TRADE_NORMAL_NORMAL_URL=https://...
DESK_E_TRADE_CONSERVATIVE_BOOST_URL=https://...
DESK_E_TRADE_CONSERVATIVE_NORMAL_URL=https://...
DESK_E_NO_TRADE_URL=https://...

# Bot F — Thesis-maximizing combined bot. Asymmetric IC × VVIX × DOW × tail hedge.
# 8 trade variants + NO_TRADE. EXTREME variants attach long Δ5 put hedge on OA side.
# Peak-EV label is TRADE_EXTREME_BOOST_HEDGED (high-VVIX Friday entry).
# SKIP fires on: composite SKIP, Thursday entry, or VVIX percentile ≥ 99.
[WEBHOOKS_DESK_F]
DESK_F_TRADE_LOW_NORMAL_URL=https://...
DESK_F_TRADE_LOW_BOOST_URL=https://...
DESK_F_TRADE_NORMAL_NORMAL_URL=https://...
DESK_F_TRADE_NORMAL_BOOST_URL=https://...
DESK_F_TRADE_HIGH_NORMAL_URL=https://...
DESK_F_TRADE_HIGH_BOOST_URL=https://...
DESK_F_TRADE_EXTREME_NORMAL_HEDGED_URL=https://...
DESK_F_TRADE_EXTREME_BOOST_HEDGED_URL=https://...
DESK_F_NO_TRADE_URL=https://...

# Optional: log each signal to Google Sheets (for history/backtesting)
# Same for local and Railway: use GOOGLE_CREDENTIALS_JSON (minified one-line service account JSON).
[GOOGLE_SHEETS]
GOOGLE_SHEET_ID=your_spreadsheet_id_from_url
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@....iam.gserviceaccount.com",...}
